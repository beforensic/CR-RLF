# --- Database ---
# Use Render's "Internal Database URL" in production.
DATABASE_URL="postgresql://user:password@host:5432/cr_rlf?schema=public"

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxx"

# Clerk URL overrides (keep these exact values — they match the app routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-in"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- App ---
# Public URL (used for building Clerk invitation links).
# On Render, set to the service's external URL, e.g. https://cr-rlf-osint.onrender.com
APP_URL="http://localhost:3000"
